# ── TimescaleDB ────────────────────────────────────────────────────────────────
# Connects to the timescaledb service in real-time-market-data via shared Docker network
TIMESCALEDB_URL=jdbc:postgresql://timescaledb:5432/binance
SPRING_DATASOURCE_URL=jdbc:postgresql://timescaledb:5432/binance
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# ── Kafka ──────────────────────────────────────────────────────────────────────
# Connects to the kafka service in real-time-market-data via shared Docker network
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
